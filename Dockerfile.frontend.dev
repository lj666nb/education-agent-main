FROM node:20-alpine

ARG NPM_REGISTRY=https://registry.npmmirror.com

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm config set registry ${NPM_REGISTRY} && npm ci

# Copy Monaco Editor to public directory for local loading (avoids CDN)
RUN mkdir -p /app/public/monaco-editor/min && cp -r /app/node_modules/monaco-editor/min/vs /app/public/monaco-editor/min/vs

COPY . .

# Clear Vite dependency cache on startup to prevent stale/broken pre-bundling
# that can cause "Failed to fetch dynamically imported module" errors
CMD ["sh", "-c", "rm -rf /app/node_modules/.vite && npm run dev -- --host 0.0.0.0"]
