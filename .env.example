USE_SQLITE=false

# PostgreSQL (Docker pgvector)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=education_agent
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=root
MONGODB_PASSWORD=123456
MONGODB_DB=education_agent

# JWT
SECRET_KEY=education-agent-secret-key-change-in-production-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security
BCRYPT_COST_FACTOR=12
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15

# ========== LLM API 配置（AI 出题/对话/学习路径等功能必需） ==========
# DeepSeek（推荐，速度更快）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# Qwen（备用，当 DeepSeek 未配置时自动使用）
QWEN_API_KEY=your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Unsplash 图片搜索（可选，用于学习资源配图）
UNSPLASH_ACCESS_KEY=
